{
  "name": "shared-images",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/images/src",
  "projectType": "library",
  "tags": ["scope:shared", "type:images"],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/images",
        "main": "libs/images/src/index.ts",
        "tsConfig": "libs/images/tsconfig.lib.json",
        "assets": []
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec vitest run --config libs/images/vitest.config.mts"
      }
    }
  }
}
